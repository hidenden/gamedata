{
  // Use this repository's uv-managed virtual environment
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // Resolve src-layout package (`src/gamedata`) directly for static analysis
  "python.analysis.extraPaths": [
    "${workspaceFolder}/src"
  ],

  // Ensure Jupyter uses the selected interpreter for notebooks
  "jupyter.kernels.excludePythonEnvironments": []
}
